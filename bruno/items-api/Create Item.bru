meta {
  name: Create Item
  type: http
  seq: 1
}

post {
  url: {{base_url}}/items
  body: json
  auth: none
}

body:json {
  {
    "name": "hello world",
    "price": 1.50
  }
}

script:post-response {
  // Store the item ID for later use
  if (res.getStatus() === 201 || res.getStatus() === 200) {
    const body = res.getBody();
    bru.setVar("item_id", body.id);
  }
}
