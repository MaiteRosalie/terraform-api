{
  "name": "items-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "node esbuild.mjs",
    "dev": "sam local start-api --template template.yaml",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.{ts,tsx}' --ext .ts --max-warnings 0",
    "check": "npm run typecheck && npm run lint",
    "pack": "npm run build && npm run zip",
    "zip": "zip -j ../items-api.zip dist/index.js",
    "test": "jest"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3",
    "@aws-sdk/lib-dynamodb": "^3",
    "uuid": "^11",
    "zod": "^4"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "esbuild": "^0.25",
    "eslint": "^10.4.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5"
  }
}
